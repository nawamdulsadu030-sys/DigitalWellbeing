<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="20dp"
    android:background="#0F0F1A">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Digital Wellbeing"
        android:textColor="#E2E8F0"
        android:textSize="22sp"
        android:textStyle="bold"
        android:layout_marginBottom="4dp" />

    <TextView
        android:id="@+id/tv_perm_status"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Checking permissions..."
        android:textSize="12sp"
        android:layout_marginBottom="24dp" />

    <!-- Stats card -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#1A1A2E"
        android:padding="16dp"
        android:orientation="vertical"
        android:layout_marginBottom="12dp">

        <TextView
            android:id="@+id/tv_total_usage"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Today: 0:00"
            android:textColor="#A78BFA"
            android:textSize="28sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tv_monitored_count"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0 apps monitored"
            android:textColor="#888888"
            android:textSize="13sp"
            android:layout_marginTop="4dp" />
    </LinearLayout>

    <!-- Buttons -->
    <Button
        android:id="@+id/btn_select_apps"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Select Apps to Monitor"
        android:backgroundTint="#7C3AED"
        android:layout_marginBottom="10dp" />

    <Button
        android:id="@+id/btn_limits"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Set Time Limits"
        android:backgroundTint="#5B21B6"
        android:layout_marginBottom="10dp" />

    <Button
        android:id="@+id/btn_permissions"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Setup Permissions (Honor)"
        android:backgroundTint="#374151"
        android:layout_marginBottom="10dp" />

</LinearLayout>
